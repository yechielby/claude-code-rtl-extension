{
  "name": "claude-code-rtl",
  "displayName": "Claude Code RTL Support",
  "description": "Adds RTL (Right-to-Left) text support for Hebrew, Arabic and Persian to Claude Code in VS Code, Cursor and Antigravity",
  "version": "0.3.7",
  "publisher": "yechielby",
  "license": "MIT",
  "homepage": "https://github.com/YechielBy/claude-code-rtl-extension#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/YechielBy/claude-code-rtl-extension"
  },
  "bugs": {
    "url": "https://github.com/YechielBy/claude-code-rtl-extension/issues"
  },
  "engines": {
    "vscode": "^1.94.0"
  },
  "categories": [
    "Other",
    "Language Packs"
  ],
  "keywords": [
    "arabic",
    "arabic-language",
    "bidi",
    "bidirectional",
    "claude-code",
    "claude-code-plugin",
    "cursor",
    "cursor-extension",
    "cursor-ide",
    "cursor-plugin",
    "antigravity",
    "antigravity-extension",
    "antigravity-ide",
    "antigravity-plugin",
    "kiro",
    "kiro-extension",
    "kiro-ide",
    "kiro-plugin",
    "farsi",
    "farsi-language",
    "hebrew",
    "hebrew-language",
    "persian",
    "persian-language",
    "rtl",
    "rtl-support",
    "vs-code",
    "vs-code-extension",
    "vscode",
    "vscode-extension",
    "right-to-left",
    "text-direction",
    "claude",
    "anthropic",
    "ai-chat"
  ],
  "extensionDependencies": [
    "anthropic.claude-code"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "badges": [
    {
      "url": "https://img.shields.io/github/stars/YechielBy/claude-code-rtl-extension?style=social",
      "href": "https://github.com/YechielBy/claude-code-rtl-extension/stargazers",
      "description": "Star on GitHub"
    }
  ],
  "icon": "claude-code-rtl-logo.png",
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "Claude RTL",
      "properties": {
        "claude-rtl.textFont": {
          "type": "string",
          "default": "",
          "markdownDescription": "Font family for text/prose areas in Claude Code (e.g. `Vazirmatn`, `Tahoma`). Leave empty to use default."
        },
        "claude-rtl.codeFont": {
          "type": "string",
          "default": "",
          "markdownDescription": "Font family for code blocks in Claude Code (e.g. `JetBrains Mono`, `Fira Code`). Leave empty to use default."
        }
      }
    },
    "commands": [
      {
        "command": "claude-rtl.add",
        "title": "Claude RTL: Activate RTL"
      },
      {
        "command": "claude-rtl.addAlways",
        "title": "Claude RTL: Activate RTL (Always)"
      },
      {
        "command": "claude-rtl.addAuto",
        "title": "Claude RTL: Activate RTL (Auto)"
      },
      {
        "command": "claude-rtl.remove",
        "title": "Claude RTL: Deactivate RTL"
      },
      {
        "command": "claude-rtl.fixBidi",
        "title": "Claude RTL: Fix BiDi"
      },
      {
        "command": "claude-rtl.status",
        "title": "Claude RTL: Check Status"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.mjs --production",
    "watch": "node esbuild.mjs --watch",
    "package": "npx @vscode/vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.94.0",
    "@types/node": "^20.0.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.7.0"
  }
}
